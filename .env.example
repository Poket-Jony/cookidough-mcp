# Cookidoo account credentials
COOKIDOO_EMAIL=you@example.com
COOKIDOO_PASSWORD=change-me

# Locale. COUNTRY is ISO 3166-1 alpha-2. LANGUAGE accepts either a bare
# ISO 639-1 code (de, en) which is paired with COUNTRY automatically, or an
# explicit BCP-47 tag (de-DE, en-GB). Case is normalized internally.
COOKIDOO_COUNTRY=de
COOKIDOO_LANGUAGE=de

# Transport: stdio (default) or http
COOKIDOO_MCP_MODE=stdio
COOKIDOO_MCP_HOST=127.0.0.1
COOKIDOO_MCP_PORT=8765

# Minimum TM7 quality score to allow custom-recipe upload (0-100)
COOKIDOO_QUALITY_BAR=70
