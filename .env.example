# Cookidoo account credentials
COOKIDOUGH_EMAIL=you@example.com
COOKIDOUGH_PASSWORD=change-me

# Locale. COUNTRY is ISO 3166-1 alpha-2. LANGUAGE accepts either a bare
# ISO 639-1 code (de, en) which is paired with COUNTRY automatically, or an
# explicit BCP-47 tag (de-DE, en-GB). Case is normalized internally.
COOKIDOUGH_COUNTRY=de
COOKIDOUGH_LANGUAGE=de

# Transport: stdio (default) or http
COOKIDOUGH_MCP_MODE=stdio
COOKIDOUGH_MCP_HOST=127.0.0.1
COOKIDOUGH_MCP_PORT=8765

# Minimum quality score to allow custom-recipe upload (0-100)
COOKIDOUGH_QUALITY_BAR=70
